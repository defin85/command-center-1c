# Environment Configuration Example
# Copy this file to .env and update with your values

# General
ENV=development
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://commandcenter:dev_password@postgres:5432/commandcenter
POSTGRES_DB=commandcenter
POSTGRES_USER=commandcenter
POSTGRES_PASSWORD=dev_password_change_in_prod

# Redis
REDIS_URL=redis://redis:6379/0

# ClickHouse
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=commandcenter
CLICKHOUSE_USER=commandcenter
CLICKHOUSE_PASSWORD=dev_password_change_in_prod

# Django
SECRET_KEY=dev-secret-key-change-in-prod-must-be-50-chars-minimum
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=config.settings.dev

# API Gateway (Go)
ORCHESTRATOR_URL=http://orchestrator:8000
JWT_SECRET=dev-jwt-secret-change-in-prod-must-be-secure
API_PORT=8080
LOG_LEVEL=debug

# Workers
WORKER_CONCURRENCY=20
MAX_RETRIES=3
RETRY_DELAY=60

# Frontend
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080/ws
NODE_ENV=development

# Monitoring
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# 1C OData Settings
ONEC_DEFAULT_TIMEOUT=30
ONEC_MAX_CONNECTIONS_PER_BASE=5
ONEC_RETRY_ATTEMPTS=3

# Email (for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080

# Performance
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
