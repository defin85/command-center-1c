# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=*

# Database encryption key (generate with: python scripts/generate_encryption_key.py)
DB_ENCRYPTION_KEY=your-generated-key-here

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commandcenter
DB_USER=commandcenter
DB_PASSWORD=password
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Go Services
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ORCHESTRATOR_URL=http://localhost:8000

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE_TIME=24h
JWT_ISSUER=commandcenter1c

# Worker
WORKER_POOL_SIZE=50
WORKER_MAX_RETRIES=3
WORKER_TIMEOUT=5m

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws

# Installation Service (Go microservice for 1C cluster administration)
INSTALLATION_SERVICE_URL=http://localhost:8085
INSTALLATION_SERVICE_TIMEOUT=180
