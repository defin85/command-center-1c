##############################################################################
# CommandCenter1C - Local Development Environment Variables
##############################################################################
# Этот файл используется для локального запуска сервисов на хост-машине
# (не в Docker контейнерах)
#
# Скопируйте этот файл в .env.local и настройте под свое окружение:
#   cp .env.local.example .env.local
##############################################################################

# Django Settings
DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database encryption key (generate with: python scripts/generate_encryption_key.py)
DB_ENCRYPTION_KEY=your-generated-key-here

##############################################################################
# Database (PostgreSQL)
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'postgres' как в Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commandcenter
DB_USER=commandcenter
DB_PASSWORD=password
DB_SSLMODE=disable

##############################################################################
# Redis
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'redis' как в Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery (используется Redis как broker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

##############################################################################
# Go Services Configuration
##############################################################################
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ВАЖНО: localhost для локального запуска
ORCHESTRATOR_URL=http://localhost:8000

##############################################################################
# JWT Authentication
##############################################################################
JWT_SECRET=local-jwt-secret-change-in-production
JWT_EXPIRE_TIME=24h
JWT_ISSUER=commandcenter1c

##############################################################################
# Worker Configuration
##############################################################################
WORKER_POOL_SIZE=50
WORKER_MAX_RETRIES=3
WORKER_TIMEOUT=5m
REDIS_QUEUE_KEY=operations_queue

##############################################################################
# Logging
##############################################################################
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=stdout

##############################################################################
# Metrics (Prometheus)
##############################################################################
METRICS_ENABLED=true
METRICS_PORT=9090

##############################################################################
# Frontend (React/Vite)
##############################################################################
# ВАЖНО: localhost для локального запуска
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws

##############################################################################
# Cluster Service (Go microservice for 1C cluster administration)
##############################################################################
# ВАЖНО: localhost для локального запуска
CLUSTER_SERVICE_URL=http://localhost:8088
CLUSTER_SERVICE_TIMEOUT=30

##############################################################################
# RAS gRPC Gateway (1C Remote Administration Server Gateway)
##############################################################################
# RAS_SERVER может быть:
# - host.docker.internal:1545 (если 1C на хосте, а gateway в Docker)
# - localhost:1545 (если 1C локально)
# - remote-server:1545 (если 1C на удаленном сервере)
RAS_SERVER=host.docker.internal:1545

# ВАЖНО: localhost если ras-grpc-gw в Docker
GRPC_GATEWAY_ADDR=localhost:9999
GRPC_CONN_TIMEOUT=5s
GRPC_REQUEST_TIMEOUT=10s

##############################################################################
# Batch Service (Go microservice for batch operations)
##############################################################################
BATCH_SERVICE_URL=http://localhost:8087
BATCH_SERVICE_TIMEOUT=30

##############################################################################
# ClickHouse (Analytics) - Optional
##############################################################################
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=commandcenter
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

##############################################################################
# Development Options
##############################################################################
# Режим разработки - дополнительное логирование, hot reload и т.д.
ENV=development

# Горячая перезагрузка для Go сервисов (требует air или аналог)
HOT_RELOAD=false

# CORS разрешения для локальной разработки
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

##############################################################################
# 1C Connection (для тестирования)
##############################################################################
# Эти переменные используются для integration тестов
ONEC_BASE_URL=http://your-1c-server/base/odata/standard.odata
ONEC_USERNAME=admin
ONEC_PASSWORD=password
ONEC_TIMEOUT=30
