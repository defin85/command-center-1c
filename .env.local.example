##############################################################################
# CommandCenter1C - Local Development Environment Variables
##############################################################################
# Этот файл используется для локального запуска сервисов на хост-машине
# (не в Docker контейнерах)
#
# Скопируйте этот файл в .env.local и настройте под свое окружение:
#   cp .env.local.example .env.local
##############################################################################

# Django Settings
DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Django Superuser (создаётся автоматически при bootstrap)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost
DJANGO_SUPERUSER_PASSWORD=p-123456

# Database encryption key (генерируется автоматически при bootstrap)
DB_ENCRYPTION_KEY=your-generated-key-here

##############################################################################
# Database (PostgreSQL)
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'postgres' как в Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commandcenter
DB_USER=commandcenter
DB_PASSWORD=password
DB_SSLMODE=disable

##############################################################################
# Redis
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'redis' как в Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery (используется Redis как broker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

##############################################################################
# Go Services Configuration
##############################################################################
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ВАЖНО: localhost для локального запуска
ORCHESTRATOR_URL=http://localhost:8000

##############################################################################
# JWT Authentication
##############################################################################
JWT_SECRET=local-jwt-secret-change-in-production
JWT_EXPIRE_TIME=24h
JWT_ISSUER=commandcenter1c

##############################################################################
# Worker Configuration
##############################################################################
WORKER_POOL_SIZE=50
WORKER_MAX_RETRIES=3
WORKER_TIMEOUT=5m
REDIS_QUEUE_KEY=operations_queue

# Ключ шифрования для передачи credentials между сервисами (минимум 32 символа)
# Генерируется автоматически при bootstrap или: openssl rand -base64 32
CREDENTIALS_TRANSPORT_KEY=your-32-byte-key-here-change-me!

##############################################################################
# Logging
##############################################################################
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=stdout

##############################################################################
# Metrics (Prometheus)
##############################################################################
METRICS_ENABLED=true
METRICS_PORT=9090

##############################################################################
# OpenTelemetry / Tracing (Jaeger)
##############################################################################
# OTLP endpoint для отправки трейсов (порт 14317 из-за конфликтов в WSL2)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317
# Отключить tracing если Jaeger не запущен
OTEL_SDK_DISABLED=false

##############################################################################
# Frontend (React/Vite)
##############################################################################
# ВАЖНО: localhost для локального запуска
# VITE_* variables moved to frontend/.env.local (standard Vite approach)

##############################################################################
# RAS Adapter (Go microservice for 1C cluster administration)
##############################################################################
# ВАЖНО: localhost для локального запуска
# Port 8188 - outside Windows reserved range (8013-8112)
RAS_ADAPTER_URL=http://localhost:8188
RAS_ADAPTER_PORT=8188

##############################################################################
# RAS Server (1C Remote Administration Server)
##############################################################################
# RAS_SERVER может быть:
# - host.docker.internal:1545 (если 1C на хосте, а сервисы в WSL/Docker)
# - localhost:1545 (если 1C локально)
# - remote-server:1545 (если 1C на удаленном сервере)
RAS_SERVER=host.docker.internal:1545
RAS_PORT=1545

##############################################################################
# Batch Service (Go microservice for batch operations)
##############################################################################
# Port 8187 - outside Windows reserved range (8013-8112)
BATCH_SERVICE_URL=http://localhost:8187
BATCH_SERVICE_PORT=8187
BATCH_SERVICE_TIMEOUT=30

##############################################################################
# ClickHouse (Analytics) - Optional
##############################################################################
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=commandcenter
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

##############################################################################
# Development Options
##############################################################################
# Режим разработки - дополнительное логирование, hot reload и т.д.
ENV=development

# Горячая перезагрузка для Go сервисов (требует air или аналог)
HOT_RELOAD=false

# CORS разрешения для локальной разработки
# Port 8180 - outside Windows reserved range (8013-8112)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8180

##############################################################################
# 1C Platform Path
##############################################################################
# Путь к директории bin платформы 1С (для запуска ras.exe, ragent.exe, 1cv8.exe)
# Bootstrap автоматически подставит правильный формат для вашей платформы:
#
# WSL (Arch/Ubuntu под Windows):
#   PLATFORM_1C_BIN_PATH="/mnt/c/Program Files/1cv8/8.3.27.1786/bin"
#
# Native Windows (Git Bash / PowerShell):
#   PLATFORM_1C_BIN_PATH="C:\Program Files\1cv8\8.3.27.1786\bin"
#
# Native Linux:
#   PLATFORM_1C_BIN_PATH="/opt/1cv8/x86_64/8.3.27.1786"
#
# ВАЖНО: Измените версию платформы (8.3.27.1786) на установленную у вас!
PLATFORM_1C_BIN_PATH="C:\Program Files\1cv8\8.3.27.1786\bin"

# RAS Server порт (Remote Administration Server)
RAS_PORT=1545

##############################################################################
# 1C Connection (для тестирования)
##############################################################################
# Эти переменные используются для integration тестов
ONEC_BASE_URL=http://your-1c-server/base/odata/standard.odata
ONEC_USERNAME=admin
ONEC_PASSWORD=password
ONEC_TIMEOUT=30
