##############################################################################
# CommandCenter1C - Local Development Environment Variables
##############################################################################
# Этот файл используется для локального запуска сервисов на хост-машине
# (не в Docker контейнерах)
#
# Скопируйте этот файл в .env.local и настройте под свое окружение:
#   cp .env.local.example .env.local
##############################################################################

##############################################################################
# Infrastructure Mode
##############################################################################
# USE_DOCKER=true (default) - PostgreSQL, Redis, Prometheus, Grafana run in Docker
# USE_DOCKER=false          - All infrastructure runs natively via systemd (Arch Linux)
#
# Native mode requirements (Arch Linux):
#   pacman -S postgresql redis prometheus grafana
#   sudo systemctl enable postgresql redis prometheus grafana
#
# Note: Application services (Go, Python, Node.js) always run on host
USE_DOCKER=true

# Django Settings
DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Django Superuser (создаётся автоматически при bootstrap)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost
DJANGO_SUPERUSER_PASSWORD=p-123456

# Database encryption key (генерируется автоматически при bootstrap)
DB_ENCRYPTION_KEY=your-generated-key-here

##############################################################################
# Database (PostgreSQL)
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'postgres' как в Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commandcenter
DB_USER=commandcenter
DB_PASSWORD=password
DB_SSLMODE=disable

##############################################################################
# Redis
##############################################################################
# ВАЖНО: localhost для локального запуска (не 'redis' как в Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO (Artifact Storage)
##############################################################################
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cc1c-artifacts
MINIO_SECURE=false

# Celery использует REDIS_URL (составляется из REDIS_HOST:REDIS_PORT)
# REDIS_URL=redis://localhost:6379/0  # опционально, если нужен другой формат

##############################################################################
# Go Services Configuration
##############################################################################
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ВАЖНО: localhost для локального запуска
ORCHESTRATOR_URL=http://localhost:8000

##############################################################################
# JWT Authentication
##############################################################################
JWT_SECRET=local-jwt-secret-change-in-production
JWT_EXPIRE_TIME=24h
JWT_ISSUER=commandcenter1c

##############################################################################
# Worker Configuration
##############################################################################
WORKER_POOL_SIZE=50
WORKER_MAX_RETRIES=3
WORKER_TIMEOUT=5m
REDIS_QUEUE_KEY=operations_queue

##############################################################################
# State Machine Configuration (Worker)
##############################################################################
# Timeouts for each step (Go duration format: 30s, 5m, 1h)
SM_TIMEOUT_LOCK=30s              # Timeout for locking infobase
SM_TIMEOUT_TERMINATE=90s         # Timeout for terminating sessions
SM_TIMEOUT_INSTALL=5m            # Timeout for installing extension
SM_TIMEOUT_UNLOCK=30s            # Timeout for unlocking infobase
SM_TIMEOUT_COMPENSATION=2m       # Timeout for compensation actions

# Retry configuration
SM_MAX_RETRIES=3                 # Maximum retry attempts
SM_RETRY_INITIAL_DELAY=1s        # Initial retry delay
SM_RETRY_MAX_DELAY=30s           # Maximum retry delay
SM_RETRY_MULTIPLIER=2.0          # Exponential backoff multiplier

# State persistence
SM_STATE_TTL=24h                 # TTL for state in Redis
SM_DEDUPLICATION_TTL=10m         # TTL for deduplication keys

# Ключ шифрования для передачи credentials между сервисами (AES-256, hex-encoded)
# ВАЖНО: Go Worker ожидает HEX (64+ hex chars = 32+ bytes)
# Генерируется автоматически при bootstrap или: openssl rand -hex 32
CREDENTIALS_TRANSPORT_KEY=your-64-hex-chars-key-here-change-me!

##############################################################################
# Logging
##############################################################################
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=stdout

##############################################################################
# Metrics (Prometheus)
##############################################################################
METRICS_ENABLED=true
METRICS_PORT=9090

##############################################################################
# OpenTelemetry / Tracing (Jaeger)
##############################################################################
# OTLP endpoint для отправки трейсов (порт 14317 из-за конфликтов в WSL2)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317
# Отключить tracing если Jaeger не запущен
OTEL_SDK_DISABLED=false

##############################################################################
# Frontend (React/Vite)
##############################################################################
# ВАЖНО: localhost для локального запуска
# VITE_* variables moved to frontend/.env.local (standard Vite approach)

##############################################################################
# RAS Adapter (Go microservice for 1C cluster administration)
##############################################################################
# ВАЖНО: localhost для локального запуска
# Port 8188 - outside Windows reserved range (8013-8112)
RAS_ADAPTER_URL=http://localhost:8188
RAS_ADAPTER_PORT=8188

##############################################################################
# RAS Server (1C Remote Administration Server)
##############################################################################
# RAS_SERVER может быть:
# - localhost:1645 (если ragent/ras запущены локально в WSL)
# - host.docker.internal:1645 (если 1C на Windows-host, а сервисы в WSL/Docker)
# - remote-server:1645 (если 1C на удаленном сервере)
# - 192.168.32.143:1645 (пример для отдельной VM с 1C)
RAS_SERVER=192.168.32.143:1645
RAS_SERVER_ADDR=192.168.32.143:1645
RAS_PORT=1645

##############################################################################
# Batch Service (Go microservice for batch operations)
##############################################################################
# Port 8187 - outside Windows reserved range (8013-8112)
BATCH_SERVICE_URL=http://localhost:8187
BATCH_SERVICE_PORT=8187
BATCH_SERVICE_TIMEOUT=30

##############################################################################
# Event-Driven Architecture
##############################################################################
# Включить Event-Driven режим (Redis Pub/Sub + State Machine)
# true = Event-Driven mode (рекомендуется)
# false = отключено (для отладки)
ENABLE_EVENT_DRIVEN=true

# Redis Pub/Sub для ras-adapter и batch-service
# Должно быть true когда ENABLE_EVENT_DRIVEN=true
REDIS_PUBSUB_ENABLED=true

# Consumer group для Worker State Machine
WORKER_CONSUMER_GROUP=worker-state-machine

##############################################################################
# Go Worker Feature Flags (Phase 0.3)
##############################################################################
# Постепенный rollout Go компонентов вместо Celery
# false (default) = используем Celery
# true = используем соответствующий Go компонент

# Go Scheduler вместо Celery Beat для периодических задач
ENABLE_GO_SCHEDULER=false

# Go Template Engine вместо Django для рендеринга шаблонов операций
ENABLE_GO_TEMPLATE_ENGINE=false

# Go Workflow Engine вместо Celery для оркестрации операций
ENABLE_GO_WORKFLOW_ENGINE=false

# Feature flag: включить poolops route для pool.* workflow operation nodes.
# false = route выключен (pool.* завершатся fail-closed с POOL_RUNTIME_ROUTE_DISABLED)
# true = route включен через canonical poolops bridge
ENABLE_POOLOPS_ROUTE=false

# Canary rollout poolops route по workflow workers.
# Диапазон: 0.0..1.0 (1.0 = 100% workers, 0.1 = 10% workers).
POOLOPS_ROUTE_ROLLOUT_PERCENT=1.0
# Опциональный seed для стабильного A/B распределения worker cohorts.
POOLOPS_ROUTE_ROLLOUT_SEED=
# Kill-switch: мгновенно отключает poolops route для новых execution.
# При true pool.* шаги остаются fail-closed (POOL_RUNTIME_ROUTE_DISABLED), без legacy fallback.
POOLOPS_ROUTE_KILL_SWITCH=false
# Projection hardening управляется отдельно через runtime setting:
# pools.projection.publication_hardening_cutoff_utc

# Internal API Token для аутентификации Go Worker при вызове Django API
# КРИТИЧНО: Должен совпадать между Django Orchestrator и Go Worker
# Генерировать: openssl rand -hex 32
INTERNAL_API_TOKEN=dev-internal-token-change-in-production

##############################################################################
# ClickHouse (Analytics) - Optional
##############################################################################
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=commandcenter
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

##############################################################################
# Development Options
##############################################################################
# Режим разработки - дополнительное логирование, hot reload и т.д.
ENV=development

# Горячая перезагрузка для Go сервисов (требует air или аналог)
HOT_RELOAD=false

# CORS разрешения для локальной разработки
# Port 8180 - outside Windows reserved range (8013-8112)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8180

##############################################################################
# 1C Platform Path
##############################################################################
# Путь к директории bin платформы 1С (для запуска ras.exe, ragent.exe, 1cv8.exe)
# Bootstrap автоматически подставит правильный формат для вашей платформы:
#
# WSL (Arch/Ubuntu под Windows):
#   PLATFORM_1C_BIN_PATH="/mnt/c/Program Files/1cv8/8.3.27.1786/bin"
#
# Native Windows (Git Bash / PowerShell):
#   PLATFORM_1C_BIN_PATH="C:\Program Files\1cv8\8.3.27.1786\bin"
#
# Native Linux:
#   PLATFORM_1C_BIN_PATH="/opt/1cv8/x86_64/8.3.27.1786"
#
# ВАЖНО: Измените версию платформы (8.3.27.1786) на установленную у вас!
PLATFORM_1C_BIN_PATH="C:\Program Files\1cv8\8.3.27.1786\bin"

# RAS Server порт (Remote Administration Server)
RAS_PORT=1645

##############################################################################
# 1C Connection (для тестирования)
##############################################################################
# Эти переменные используются для integration тестов
ONEC_BASE_URL=http://your-1c-server/base/odata/standard.odata
ONEC_USERNAME=admin
ONEC_PASSWORD=password
ONEC_TIMEOUT=30
