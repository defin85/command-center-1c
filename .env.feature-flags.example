# ========================================
# Feature Flags Configuration Examples
# ========================================
# Task 3.2.1: Feature Flags Implementation
# Last Updated: 2025-11-18

# ========================================
# Example 1: FULL ROLLBACK (Emergency)
# ========================================
# Use Case: Критичный баг, нужен instant rollback
# Time to Rollback: < 1 second

ENABLE_EVENT_DRIVEN=false


# ========================================
# Example 2: DISABLED (Default)
# ========================================
# Use Case: Initial state, Event-Driven не используется

ENABLE_EVENT_DRIVEN=false
EVENT_DRIVEN_ROLLOUT_PERCENT=0.0
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false
EVENT_DRIVEN_MAX_CONCURRENT=100
EVENT_DRIVEN_CB_THRESHOLD=0.95
EVENT_DRIVEN_EXPERIMENT_ID=


# ========================================
# Example 3: TARGETED ROLLOUT (Early Access)
# ========================================
# Use Case: Тестирование на specific базах

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=0.0
EVENT_DRIVEN_TARGET_DBS=test-db-1,test-db-2,test-db-3
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false


# ========================================
# Example 4: 10% GRADUAL ROLLOUT
# ========================================
# Use Case: Week 1 of gradual rollout

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=0.10
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false


# ========================================
# Example 5: 25% GRADUAL ROLLOUT
# ========================================
# Use Case: Week 2 of gradual rollout

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=0.25
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false


# ========================================
# Example 6: 50% A/B TESTING
# ========================================
# Use Case: Сравнение Event-Driven vs HTTP Sync
# Feature: Consistent hashing (одна база → один режим)

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=0.50
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false
EVENT_DRIVEN_EXPERIMENT_ID=exp-2025-week3


# ========================================
# Example 7: 100% ROLLOUT (Full Migration)
# ========================================
# Use Case: Final stage, все операции → Event-Driven

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=1.0
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false


# ========================================
# Example 8: CANARY DEPLOYMENT
# ========================================
# Use Case: Canary group (10 production баз)

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=0.0
EVENT_DRIVEN_TARGET_DBS=prod-db-001,prod-db-002,prod-db-003,prod-db-004,prod-db-005,prod-db-006,prod-db-007,prod-db-008,prod-db-009,prod-db-010
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=false


# ========================================
# Example 9: MIXED MODE (Extensions + Backups)
# ========================================
# Use Case: Event-Driven для extensions, HTTP Sync для backups

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=1.0
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true    # Event-Driven
EVENT_DRIVEN_BACKUPS=false      # HTTP Sync


# ========================================
# Example 10: HIGH CONCURRENCY
# ========================================
# Use Case: Production с большим количеством параллельных операций

ENABLE_EVENT_DRIVEN=true
EVENT_DRIVEN_ROLLOUT_PERCENT=1.0
EVENT_DRIVEN_TARGET_DBS=
EVENT_DRIVEN_EXTENSIONS=true
EVENT_DRIVEN_BACKUPS=true
EVENT_DRIVEN_MAX_CONCURRENT=500          # Увеличено для production
EVENT_DRIVEN_CB_THRESHOLD=0.90           # Circuit breaker при 90% errors


# ========================================
# Notes
# ========================================

# 1. GLOBAL KILL SWITCH
#    ENABLE_EVENT_DRIVEN=false → мгновенный rollback
#    Все операции переключаются на HTTP Sync < 1 секунды

# 2. PERCENTAGE ROLLOUT
#    0.0  = 0%   (только whitelist)
#    0.10 = 10%  (10% баз → Event-Driven)
#    0.50 = 50%  (50% баз → Event-Driven)
#    1.0  = 100% (все базы → Event-Driven)

# 3. DATABASE TARGETING
#    Whitelist баз для early access
#    Формат: comma-separated list (db1,db2,db3)
#    Whitelist имеет приоритет над percentage rollout

# 4. OPERATION TYPE FILTERING
#    EVENT_DRIVEN_EXTENSIONS - установка расширений
#    EVENT_DRIVEN_BACKUPS - backup операции
#    Можно включить независимо друг от друга

# 5. A/B TESTING
#    EVENT_DRIVEN_EXPERIMENT_ID - ID эксперимента
#    Включает consistent hashing (одна база → один режим)
#    Используйте для статистически достоверных сравнений

# 6. CIRCUIT BREAKER
#    EVENT_DRIVEN_CB_THRESHOLD - порог для circuit breaker
#    0.95 = при 95% ошибок переключиться на fallback
#    Защита от cascade failures

# 7. HOT RELOAD
#    Изменения environment variables применяются при перезапуске Worker
#    FUTURE: Hot reload без перезапуска (Task 3.2.3)

# 8. MONITORING
#    Все решения логируются в Worker logs
#    Metrics (Prometheus) - Task 3.2.2
