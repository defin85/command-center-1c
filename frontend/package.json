{
  "name": "commandcenter1c-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:api": "orval",
    "generate:api:if-needed": "node ./scripts/run-orval-if-needed.mjs",
    "dev": "vite",
    "predev": "npm run generate:api:if-needed",
    "analyze": "ANALYZE_BUNDLE=1 npm run build:assets",
    "typecheck": "mkdir -p node_modules/.cache/tsc && tsc --incremental --tsBuildInfoFile node_modules/.cache/tsc/frontend.tsbuildinfo",
    "build:assets": "npm run typecheck && vite build",
    "build": "npm run validate:ui-platform",
    "lint": "mkdir -p node_modules/.cache/eslint && eslint . --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:ui-platform": "eslint eslint.config.js src/components/platform/*.tsx src/components/platform/__tests__/PlatformPrimitives.test.tsx src/components/platform/__tests__/UiPlatformGovernanceLint.test.ts src/components/layout/MainLayout.tsx src/pages/Dashboard/Dashboard.tsx src/pages/Decisions/*.tsx src/pages/Pools/PoolBindingProfiles*.tsx src/pages/Pools/BindingProfile*.tsx tests/browser/ui-platform-contract.spec.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:run:changed": "vitest run --changed",
    "test:run:fast": "vitest run --project fast-default",
    "test:run:heavy": "vitest run --project heavy-routes-*",
    "test:run:related": "vitest related --run",
    "test:run:decisions-heavy": "vitest run --project heavy-routes-tertiary src/pages/Decisions/__tests__/DecisionsPage.test.tsx",
    "test:run:pools-heavy": "vitest run --project heavy-routes-* src/pages/Pools/__tests__/PoolBindingProfilesPage.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.bindings.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.core.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.errors-sync.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.topology.test.tsx src/pages/Pools/__tests__/PoolFactualPage.test.tsx src/pages/Pools/__tests__/PoolMasterDataPage.test.tsx src/pages/Pools/__tests__/PoolRunsPage.test.tsx src/pages/Pools/__tests__/PoolTopologyTemplatesPage.test.tsx",
    "test:run:pools-catalog": "vitest run --project heavy-routes-* src/pages/Pools/__tests__/PoolCatalogPage.bindings.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.core.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.errors-sync.test.tsx src/pages/Pools/__tests__/PoolCatalogPage.topology.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:browser:action-catalog": "playwright test tests/browser/action-catalog-ui.spec.ts",
    "test:browser:command-schemas": "playwright test tests/browser/command-schemas-ui.spec.ts",
    "test:browser:extensions": "playwright test tests/browser/extensions-ui.spec.ts",
    "test:browser:forms": "playwright test tests/browser/form-field-ids.spec.ts",
    "test:browser:pools-full-flow": "playwright test tests/browser/pools-full-flow-ui.spec.ts",
    "test:browser:ui-platform": "playwright test tests/browser/ui-platform-contract.spec.ts --workers=1",
    "validate:ui-platform": "npm run generate:api && npm run lint && npm run test:run && npm run test:browser:ui-platform && npm run build:assets",
    "validate:ui-platform:iter": "npm run generate:api:if-needed && npm run lint && npm run test:run:changed && npm run build:assets"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@ant-design/pro-components": "^2.8.10",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@types/dagre": "^0.7.53",
    "@types/json-schema": "^7.0.15",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "antd": "^5.29.3",
    "axios": "^1.6.2",
    "dagre": "^0.8.5",
    "i18next": "^26.0.4",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.20.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.5.0",
    "socket.io-client": "^4.5.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "orval": "^7.21.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.0.8",
    "vitest": "^4.0.15"
  }
}
