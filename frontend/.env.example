# Frontend Environment Variables
# Copy this file to .env.local and adjust values as needed

# =============================================================================
# API Configuration
# =============================================================================

# API Gateway URL (all REST API calls go through this)
VITE_API_URL=http://localhost:8080/api/v2

# =============================================================================
# WebSocket Configuration
# =============================================================================

# WebSocket host for real-time updates
# Note: WebSocket connections go directly to Django Orchestrator
# because API Gateway doesn't have WebSocket proxy middleware
VITE_WS_HOST=localhost:8000

# =============================================================================
# Jaeger/Tracing Configuration
# =============================================================================

# Jaeger UI URL (for opening trace links in browser)
# API calls to Jaeger are proxied through API Gateway (/api/v2/tracing/*)
VITE_JAEGER_UI_URL=http://localhost:16686

# =============================================================================
# Feature Flags (optional)
# =============================================================================

# Set to 'true' to enable debug logging in console
# VITE_DEBUG=false
