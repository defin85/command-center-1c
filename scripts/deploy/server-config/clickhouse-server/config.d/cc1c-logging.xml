<clickhouse>
    <logger>
        <level>information</level>
        <size>100M</size>
        <count>3</count>
    </logger>
    <trace_log>
        <partition_by>toMonday(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </trace_log>
    <text_log>
        <level>information</level>
        <partition_by>toMonday(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </text_log>
    <metric_log>
        <partition_by>toMonday(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </metric_log>
    <part_log>
        <partition_by>toMonday(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </part_log>
    <asynchronous_metric_log>
        <partition_by>toMonday(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </asynchronous_metric_log>
</clickhouse>
