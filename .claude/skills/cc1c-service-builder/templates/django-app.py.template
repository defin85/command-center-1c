class {{ModelName}}Service:
    """
    Business logic для {{ModelName}}

    Разделение ответственности:
    - Views: обрабатывают HTTP requests/responses
    - Services: содержат бизнес-логику
    - Models: работают с данными
    """

    @transaction.atomic
    def create_item(self, data: Dict) -> {{ModelName}}:
        """
        Создает новый объект {{ModelName}}

        Args:
            data: Словарь с данными для создания

        Returns:
            Созданный объект {{ModelName}}

        Raises:
            ValueError: Если данные невалидны
        """
        logger.info(f"Creating {{model_name_lower}} with data: {data}")

        # Validate business rules
        self._validate_business_rules(data)

        # Create object
        item = {{ModelName}}.objects.create(**data)

        # Trigger async processing if needed
        from .tasks import process_{{model_name_lower}}_task
        process_{{model_name_lower}}_task.delay(item.id)

        logger.info(f"{{ModelName}} created: {item.id}")
        return item

    @transaction.atomic
    def update_item(self, item_id: int, data: Dict) -> {{ModelName}}:
        """
        Обновляет существующий объект

        Args:
            item_id: ID объекта
            data: Словарь с данными для обновления

        Returns:
            Обновленный объект {{ModelName}}

        Raises:
            {{ModelName}}.DoesNotExist: Если объект не найден
        """
        item = {{ModelName}}.objects.get(id=item_id)

        for field, value in data.items():
            setattr(item, field, value)

        item.save()
        logger.info(f"{{ModelName}} updated: {item.id}")
        return item

    def get_active_items(self) -> List[{{ModelName}}]:
        """Получить список активных объектов"""
        return {{ModelName}}.objects.filter(is_active=True)

    def _validate_business_rules(self, data: Dict) -> None:
