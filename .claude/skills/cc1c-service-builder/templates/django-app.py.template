from rest_framework import viewsets, status
from rest_framework.decorators import action
from rest_framework.response import Response
from rest_framework.permissions import IsAuthenticated
from django.db.models import Q
import logging

logger = logging.getLogger(__name__)


class {{ModelName}}ViewSet(viewsets.ModelViewSet):
    """
    API endpoints для управления {{ModelName}}

    list: GET /api/{{app_name}}/items/ - Получить список
    create: POST /api/{{app_name}}/items/ - Создать новый
    retrieve: GET /api/{{app_name}}/items/{id}/ - Получить по ID
    update: PUT /api/{{app_name}}/items/{id}/ - Обновить полностью
    partial_update: PATCH /api/{{app_name}}/items/{id}/ - Обновить частично
    destroy: DELETE /api/{{app_name}}/items/{id}/ - Удалить
    """
    queryset = {{ModelName}}.objects.all()
    serializer_class = {{ModelName}}Serializer
    permission_classes = [IsAuthenticated]
    filterset_fields = ['is_active']
    search_fields = ['name', 'description']
    ordering_fields = ['created_at', 'updated_at', 'name']
    ordering = ['-created_at']

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.service = {{ModelName}}Service()

    def get_queryset(self):
        """Фильтрация queryset"""
        queryset = super().get_queryset()

        # Filter by search query
        search = self.request.query_params.get('search', None)
        if search:
            queryset = queryset.filter(
                Q(name__icontains=search) |
                Q(description__icontains=search)
            )

        return queryset

    def create(self, request, *args, **kwargs):
        """Создание через service layer"""
        serializer = {{ModelName}}CreateSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)

        try:
            result = self.service.create_item(serializer.validated_data)
            output_serializer = self.get_serializer(result)
            return Response(
                output_serializer.data,
                status=status.HTTP_201_CREATED
            )
        except Exception as e:
            logger.error(f"Failed to create {{model_name_lower}}: {e}")
            return Response(
                {'error': str(e)},
                status=status.HTTP_400_BAD_REQUEST
            )

    @action(detail=True, methods=['post'])
    def activate(self, request, pk=None):
        """Активировать объект"""
        obj = self.get_object()
        obj.is_active = True
        obj.save()
        return Response({'status': 'activated'})

    @action(detail=True, methods=['post'])
    def deactivate(self, request, pk=None):
        """Деактивировать объект"""
        obj = self.get_object()
        obj.is_active = False
        obj.save()
        return Response({'status': 'deactivated'})

    @action(detail=False, methods=['get'])
    def active(self, request):
        """Получить только активные объекты"""
        active_items = self.service.get_active_items()
        serializer = self.get_serializer(active_items, many=True)
        return Response(serializer.data)


