# =============================================================================
# CommandCenter1C .gitignore
# =============================================================================

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
credentials.json
secrets.yaml

# =============================================================================
# Build Artifacts
# =============================================================================
bin/
dist/
build/
*.exe
*.dll
*.so
*.dylib

# =============================================================================
# Go
# =============================================================================
# Binaries
*.exe
*.exe~
*.out
main

# Coverage
coverage.out
coverage*.out
*.coverprofile

# Vendor (if not using modules)
# vendor/

# Go workspace (local only)
go-services/go.work
go-services/go.work.sum

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
eggs/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/
orchestrator/venv*

# Testing
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/

# Celery
celerybeat-schedule
celerybeat-schedule.*
celerybeat-schedule-shm
celerybeat-schedule-wal
celerybeat.pid

# =============================================================================
# Node.js / Frontend
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/

# =============================================================================
# IDE & Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs & PIDs
# =============================================================================
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# =============================================================================
# Test Output
# =============================================================================
test_output.log
test-results/
junit.xml

# Load test results (Locust)
orchestrator/tests/load/results/*.csv
orchestrator/tests/load/results/*.html
orchestrator/tests/load/results/*.json

# =============================================================================
# Generated Code (policy: regenerate from OpenAPI specs)
# =============================================================================
# Go generated servers
go-services/*/internal/api/generated/

# Python generated clients
orchestrator/apps/databases/clients/generated/

# Frontend generated API
frontend/src/api/generated/

# =============================================================================
# External Libraries (download separately)
# =============================================================================
# 1C RAS Java SDK
com._1c.v8.ibis.admin*/

# =============================================================================
# Tools Output
# =============================================================================
# RAS Sniffer
tools/ras-sniffer/*.log
tools/ras-sniffer/*.exe

# OpenAPI Generator
openapitools.json

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup
*.orig
*.tmp
*~

# =============================================================================
# Docker (local overrides)
# =============================================================================
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# Misc
# =============================================================================
.cache/
tmp/
temp/

# =============================================================================
# Generated Configuration (policy: regenerate from config/services.json)
# =============================================================================
# Generated config files (keep .gitkeep)
generated/*
!generated/.gitkeep

# Generated documentation
docs/generated/*
!docs/generated/.gitkeep
