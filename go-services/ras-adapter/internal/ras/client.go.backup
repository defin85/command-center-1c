package ras

import (
	"context"
	"fmt"
	"time"

	"github.com/commandcenter1c/commandcenter/ras-adapter/internal/models"
	"go.uber.org/zap"
)

// Client represents a RAS protocol client
// Week 1: Stub implementation returning mock data
// Week 2+: Real RAS binary protocol implementation
type Client struct {
	serverAddr  string
	connTimeout time.Duration
	reqTimeout  time.Duration
	logger      *zap.Logger
}

// NewClient creates a new RAS client
func NewClient(serverAddr string, connTimeout, reqTimeout time.Duration, logger *zap.Logger) (*Client, error) {
	if serverAddr == "" {
		return nil, ErrInvalidParams
	}

	if logger == nil {
		logger = zap.NewNop()
	}

	return &Client{
		serverAddr:  serverAddr,
		connTimeout: connTimeout,
		reqTimeout:  reqTimeout,
		logger:      logger,
	}, nil
}

// Close closes RAS connection
func (c *Client) Close() error {
	// No-op for Week 1 stub
	return nil
}

